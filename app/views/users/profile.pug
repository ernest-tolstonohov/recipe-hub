extends ../layout.pug

block content
  .container
    .profile-header
      .avatar-circle
        span #{profileUser.username.charAt(0).toUpperCase()}
      .profile-info
        h1 #{profileUser.username}
        p.joined Joined #{new Date(profileUser.created_at).toLocaleDateString('en-GB', { year: 'numeric', month: 'long' })}
        p.email #{profileUser.email}
        if user && user.id === profileUser.id
          a.saved-link(href='/users/' + profileUser.id + '/saved') View Saved Recipes →

    .profile-recipes
      h2 Recipes by #{profileUser.username}

      if recipes.length === 0
        //- Facebook-style empty state
        .create-post-prompt
          .create-post-avatar
            span #{profileUser.username.charAt(0).toUpperCase()}
          .create-post-box
            p #{profileUser.username} hasn't shared any recipes yet.
            if user && user.id === profileUser.id
              a.btn-create-post(href='/recipes/new') + Create a New Post
      else
        .recipe-grid
          each recipe in recipes
            a.recipe-card(href='/recipes/' + recipe.id)
              .card-img-placeholder 🍽️
              .card-body
                h3 #{recipe.title}
                p.card-desc #{recipe.description}
                .card-meta
                  if recipe.tags
                    span.tag #{recipe.tags.split(',')[0]}