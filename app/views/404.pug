    .error-layout
      .error-card
        h1.error-404-code 404
        h2.error-404-title Page Not Found
        p.error-fallback The page you're looking for doesn't exist or has been moved.
        a.btn-green(href="/", style="display:inline-block; padding:0.6rem 1.5rem;") Back to Home
