extends ../layout

block content
    .container.page-container-narrow

        .section-header
            div
                h1 Create Recipe
                p Share your recipe with the community

        if error
            .error-banner #{error}

        form(method="POST" action="/recipes/new")

            //- ── BASIC INFO ──────────────────────────────────
            .form-section
                h2 Basic Info

                .form-row-single
                    .form-group
                        label(for="title") Title *
                        input#title(type="text" name="title" value=fields.title placeholder="e.g. Classic Spaghetti Carbonara" required)

                    .form-group
                        label(for="description") Description
                        textarea#description(name="description" rows="3" placeholder="Short description of the recipe...") #{fields.description || ''}

                    .form-group
                        label(for="image_url") Image URL
                        input#image_url(type="url" name="image_url" value=fields.image_url placeholder="https://...")

                .form-row-4
                    .form-group
                        label(for="prep_time") Prep (min) *
                        input#prep_time(type="number" name="prep_time" value=fields.prep_time min="1" required)

                    .form-group
                        label(for="cook_time") Cook (min) *
                        input#cook_time(type="number" name="cook_time" value=fields.cook_time min="1" required)

                    .form-group
                        label(for="servings") Servings *
                        input#servings(type="number" name="servings" value=fields.servings min="1" required)

                    .form-group
                        label(for="difficulty") Difficulty *
                        select#difficulty(name="difficulty" required)
                            option(value="" disabled selected) Select...
                            option(value="easy" selected=fields.difficulty==='easy') Easy
                            option(value="medium" selected=fields.difficulty==='medium') Medium
                            option(value="hard" selected=fields.difficulty==='hard') Hard

            //- ── INGREDIENTS ─────────────────────────────────
            .form-section
                h2 Ingredients

                #ingredients-list
                    .ingredient-row
                        input(type="text" name="ing_name" placeholder="Ingredient name")
                        input(type="number" name="ing_qty" placeholder="Qty" min="0" step="0.01")
                        input(type="text" name="ing_unit" placeholder="Unit (g, ml...)")
                        button.btn-remove(type="button") ✕

                button#add-ingredient.btn-add-row(type="button") + Add Ingredient

            //- ── INSTRUCTIONS ────────────────────────────────
            .form-section
                h2 Instructions

                #steps-list
                    .step-row
                        .step-number 1
                        textarea(name="step_1" rows="2" placeholder="Describe this step...")
                        button.btn-remove-step(type="button") ✕

                button#add-step.btn-add-row(type="button") + Add Step

            //- ── TAGS ────────────────────────────────────────
            .form-section
                h2 Tags

                - var dietary = tags.filter(t => t.type === 'dietary')
                - var mealTypes = tags.filter(t => t.type === 'meal_type')
                - var cuisines = tags.filter(t => t.type === 'cuisine')

                .tag-group
                    p.tag-group-label Dietary
                    .tags-wrap
                        each tag in dietary
                            label.tag-checkbox-label
                                input(type="checkbox" name="tags" value=tag.tag_id)
                                span #{tag.name}

                .tag-group
                    p.tag-group-label Meal Type
                    .tags-wrap
                        each tag in mealTypes
                            label.tag-checkbox-label
                                input(type="checkbox" name="tags" value=tag.tag_id)
                                span #{tag.name}

                .tag-group
                    p.tag-group-label Cuisine
                    .tags-wrap
                        each tag in cuisines
                            label.tag-checkbox-label
                                input(type="checkbox" name="tags" value=tag.tag_id)
                                span #{tag.name}

            //- ── SUBMIT ──────────────────────────────────────
            .form-actions
                a.btn-cancel(href="/users/my-recipes") Cancel
                button.btn-green(type="submit") Publish Recipe

block scripts
    script(src="/js/recipe-form.js")
