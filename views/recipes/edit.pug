extends ../layout

block content
    .container.page-container-narrow

        .section-header
            div
                h1 Edit Recipe
                p Update your recipe

        if error
            .error-banner #{error}

        form(method="POST" action=`/recipes/${recipe.id}/edit`)

            //- ── BASIC INFO ──────────────────────────────────
            .form-section
                h2 Basic Info

                .form-row-single
                    .form-group
                        label(for="title") Title *
                        input#title(type="text" name="title" value=recipe.title required)

                    .form-group
                        label(for="description") Description
                        textarea#description(name="description" rows="3") #{recipe.description || ''}

                    .form-group
                        label(for="image_url") Image URL
                        input#image_url(type="url" name="image_url" value=recipe.image_url placeholder="https://...")

                .form-row-4
                    .form-group
                        label(for="prep_time") Prep (min) *
                        input#prep_time(type="number" name="prep_time" value=recipe.prep_time min="1" required)

                    .form-group
                        label(for="cook_time") Cook (min) *
                        input#cook_time(type="number" name="cook_time" value=recipe.cook_time min="1" required)

                    .form-group
                        label(for="servings") Servings *
                        input#servings(type="number" name="servings" value=recipe.servings min="1" required)

                    .form-group
                        label(for="difficulty") Difficulty *
                        select#difficulty(name="difficulty" required)
                            option(value="" disabled) Select...
                            option(value="easy" selected=recipe.difficulty==='easy') Easy
                            option(value="medium" selected=recipe.difficulty==='medium') Medium
                            option(value="hard" selected=recipe.difficulty==='hard') Hard

            //- ── INGREDIENTS ─────────────────────────────────
            .form-section
                h2 Ingredients

                #ingredients-list
                    each ing in ingredients
                        .ingredient-row
                            input(type="text" name="ing_name" value=ing.name)
                            input(type="number" name="ing_qty" value=ing.quantity min="0" step="0.01")
                            input(type="text" name="ing_unit" value=ing.unit)
                            button.btn-remove(type="button") ✕

                button#add-ingredient.btn-add-row(type="button") + Add Ingredient

            //- ── INSTRUCTIONS ────────────────────────────────
            .form-section
                h2 Instructions

                #steps-list
                    each step, idx in recipe.instructions
                        .step-row
                            .step-number #{idx + 1}
                            textarea(name=`step_${idx + 1}` rows="2") #{step}
                            button.btn-remove-step(type="button") ✕

                button#add-step.btn-add-row(type="button") + Add Step

            //- ── TAGS ────────────────────────────────────────
            .form-section
                h2 Tags

                - var dietary = tags.filter(t => t.type === 'dietary')
                - var mealTypes = tags.filter(t => t.type === 'meal_type')
                - var cuisines = tags.filter(t => t.type === 'cuisine')

                .tag-group
                    p.tag-group-label Dietary
                    .tags-wrap
                        each tag in dietary
                            label.tag-checkbox-label
                                input(type="checkbox" name="tags" value=tag.tag_id checked=selectedTagIds.includes(tag.tag_id))
                                span #{tag.name}

                .tag-group
                    p.tag-group-label Meal Type
                    .tags-wrap
                        each tag in mealTypes
                            label.tag-checkbox-label
                                input(type="checkbox" name="tags" value=tag.tag_id checked=selectedTagIds.includes(tag.tag_id))
                                span #{tag.name}

                .tag-group
                    p.tag-group-label Cuisine
                    .tags-wrap
                        each tag in cuisines
                            label.tag-checkbox-label
                                input(type="checkbox" name="tags" value=tag.tag_id checked=selectedTagIds.includes(tag.tag_id))
                                span #{tag.name}

            //- ── SUBMIT ──────────────────────────────────────
            .form-actions
                a.btn-cancel(href=`/recipes/${recipe.id}`) Cancel
                button.btn-green(type="submit") Save Changes

block scripts
    script(src="/js/recipe-form.js")
