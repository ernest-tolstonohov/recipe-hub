extends ../layout

block content
    .container
        .detail-header
            .recipe-title-section
                h1 #{recipe.title}
                .action-buttons
                    if user
                        button#bookmark-btn.btn.btn-bookmark(
                            class=isSaved ? 'saved' : '',
                            data-recipe-id=recipe.id,
                            data-user-id=user.id,
                            data-saved=isSaved ? 'true' : 'false'
                        )
                            span.icon #{isSaved ? '♥' : '♡'}
                            span.label #{isSaved ? ' Saved' : ' Save'}

                .author-line
                    .avatar-xs #{recipe.author ? recipe.author.charAt(0).toUpperCase() : 'U'}
                    a(href=`/users/${recipe.user_id}`) by @#{recipe.author || 'guest'}
                    span.date
                        | &bull; #{new Date(recipe.created_at).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'})}

                .meta-strip
                    .meta-item
                        span.meta-val #{recipe.prep_time} min
                        span.meta-label Prep
                    .meta-item
                        span.meta-val #{recipe.cook_time} min
                        span.meta-label Cook
                    .meta-item
                        span.meta-val #{recipe.prep_time + recipe.cook_time} min
                        span.meta-label Total
                    .meta-item
                        span.meta-val #{recipe.servings}
                        span.meta-label Serves
                    .meta-item
                        span.meta-val #{recipe.difficulty}
                        span.meta-label Level

            .detail-hero-box
                if recipe.image_url
                    img.detail-img(src=recipe.image_url, alt=recipe.title)
                else
                    .recipe-img-placeholder
                        span.placeholder-icon 🍽️
                        span.no-image-label No image

        .recipe-info
            .ingredients
                h2 Ingredients
                .servings-stepper
                    span Servings:
                    button#srv-minus -
                    span#srv-count.count #{recipe.servings}
                    button#srv-plus +

                if ingredients && ingredients.length > 0
                    ul.ingredient-list
                        each item in ingredients
                            li.ingredient-item
                                label
                                    input.ing-checkbox(type="checkbox")
                                    span.ing-text
                                        | #{item.quantity} #{item.unit} #{item.name}

                    .progress-wrapper
                        span#progress-text.progress-text You have 0 of #{ingredients.length} ingredients
                        .progress-bar
                            .progress-fill#progress-fill
                else
                    p.no-content No ingredients listed.

            .instructions
                h2 Instructions
                if Array.isArray(recipe.instructions) && recipe.instructions.length > 0
                    .instruction-steps
                        each step, index in recipe.instructions
                            .step-block
                                .step-number= index + 1
                                p= step
                else
                    p.no-content No instructions listed.

        .reviews-section
            .review-header
                span.rating-score #{parseFloat(recipe.avg_rating) > 0 ? parseFloat(recipe.avg_rating).toFixed(1) : '—'}
                .rating-info
                    span.stars
                        - var r = Math.round(parseFloat(recipe.avg_rating) || 0)
                        | #{Array(r).fill('★').join('')}#{Array(5-r).fill('☆').join('')}
                    p Based on #{recipe.review_count} review#{recipe.review_count !== 1 ? 's' : ''}

            if reviews && reviews.length > 0
                .review-grid
                    each review in reviews
                        .review-card
                            .card-author
                                .avatar-xs #{review.username.charAt(0).toUpperCase()}
                                a(href=`/users/${review.user_id}`) @#{review.username}
                            span.stars.review-stars
                                - var s = parseInt(review.rating)
                                | #{Array(s).fill('★').join('')}#{Array(5-s).fill('☆').join('')}
                            if review.body
                                p "#{review.body}"
                            p.review-date #{new Date(review.created_at).toLocaleDateString('en-GB', {day:'numeric',month:'short',year:'numeric'})}
                            if user && (user.id === review.user_id || user.role === 'admin')
                                .review-actions
                                    button.btn-edit-review(data-review-id=review.review_id, data-body=review.body, data-rating=review.rating, title="Edit review") Edit
                                    button.btn-delete-review(data-review-id=review.review_id, title="Delete review") Delete

            .write-review-box
                if user
                    h4 Write a Review
                    form#review-form
                        .stars-input
                            each star, index in [1,2,3,4,5]
                                span.star(data-rating=star) ☆
                        textarea(name="body", placeholder="Share your experience with this recipe...", required)
                        button.btn-submit(type="submit") Submit Review
                else
                    p.login-prompt
                        a(href="/login") Log in
                        |  to write a review

block scripts
    script(src="/js/bookmark.js")
    script(src="/js/review.js")
    script.
        // ── Servings stepper ─────────────────────────────
        const srvCount  = document.getElementById('srv-count');
        const srvMinus  = document.getElementById('srv-minus');
        const srvPlus   = document.getElementById('srv-plus');
        const ingTexts  = document.querySelectorAll('.ing-text');

        const baseServings = parseInt(srvCount.textContent);
        let currentServings = baseServings;

        // Store original quantities as data attributes
        ingTexts.forEach(el => {
            el.dataset.original = el.textContent.trim();
        });

        function updateIngredients() {
            const ratio = currentServings / baseServings;
            ingTexts.forEach(el => {
                const original = el.dataset.original;
                // Replace leading number (quantity) with scaled value
                el.textContent = original.replace(/^[\d.]+/, n => {
                    const scaled = parseFloat(n) * ratio;
                    return Number.isInteger(scaled) ? scaled : scaled.toFixed(2);
                });
            });
        }

        srvMinus.addEventListener('click', () => {
            if (currentServings > 1) {
                currentServings--;
                srvCount.textContent = currentServings;
                updateIngredients();
            }
        });

        srvPlus.addEventListener('click', () => {
            currentServings++;
            srvCount.textContent = currentServings;
            updateIngredients();
        });

        // ── Ingredient tick-off + progress bar ───────────
        const checkboxes = document.querySelectorAll('.ing-checkbox');
        const progressFill = document.getElementById('progress-fill');
        const progressText = document.getElementById('progress-text');
        const total = checkboxes.length;

        checkboxes.forEach(cb => {
            cb.addEventListener('change', () => {
                const checked = document.querySelectorAll('.ing-checkbox:checked').length;
                const pct = total > 0 ? (checked / total) * 100 : 0;
                if (progressFill) {
                    progressFill.style.width = pct + '%';
                    progressFill.style.background = checked === 0 ? 'transparent' : '';
                }
                if (progressText) progressText.innerText = 'You have ' + checked + ' of ' + total + ' ingredients';
                cb.closest('.ingredient-item').classList.toggle('checked', cb.checked);
            });
        });
