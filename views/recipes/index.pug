extends ../layout.pug

block content
  .container.main-layout
    .content-area
      h1(style="margin-bottom:1.5rem;color:var(--navy);") All Recipes
      if recipes && recipes.length > 0
        .recipe-grid
          each recipe in recipes
            .recipe-card(onclick=`window.location.href='/recipes/${recipe.id}'`, style="cursor:pointer;")
              .card-img-placeholder
                if recipe.image_url
                  img(src=recipe.image_url, alt=recipe.title, style="width:100%;height:100%;object-fit:cover;")
                else
                  span(style="font-size:3rem;color:#d1d5db;") 🍽️
              .card-body
                h3 #{recipe.title}
                .card-author
                  .avatar-xs #{recipe.author ? recipe.author.charAt(0).toUpperCase() : 'C'}
                  span @#{recipe.author || 'chef'}
                .card-meta
                  span(style="font-size:0.85rem;color:var(--text-muted);")
                    | ★ #{recipe.avg_rating > 0 ? parseFloat(recipe.avg_rating).toFixed(1) : 'No reviews'}
                  span(style="margin-left:auto;font-size:0.8rem;text-transform:capitalize;color:var(--text-muted);") #{recipe.difficulty}
      else
        div(style="text-align:center;padding:4rem;")
          .emoji-placeholder(style="margin-bottom:1rem;font-size:3rem;") 🥣
          h3(style="color:var(--navy);margin-bottom:0.5rem;") No recipes yet
          p(style="color:var(--text-muted);") Seed the database to see recipes here.
