extends layout.pug

block content
  .hero-section
    h1 What's in your fridge?
    p Find recipes using what you already have - reduce waste, save money.
    
    .search-widget
      .ingredient-input-area
        .chip
          span chicken
          button ×
        .chip
          span rice
          button ×
        .chip
          span garlic
          button ×
        input(type="text", placeholder="Add ingredient...", style="border:none; background:transparent; outline:none; font-size:0.9rem; margin:0;")
      
      .filter-row
        select
          option(value="") Meal Type
          option(value="breakfast") Breakfast
          option(value="lunch") Lunch
          option(value="dinner") Dinner
          option(value="snack") Snack
        select
          option(value="") Dietary
          option(value="high-protein") High Protein
          option(value="vegan") Vegan
          option(value="vegetarian") Vegetarian
          option(value="gluten-free") Gluten Free
        select
          option(value="") Difficulty
          option(value="easy") Easy
          option(value="medium") Medium
          option(value="hard") Hard
      button.btn-green Find Recipes &rarr;

  .container.main-layout
    .content-area
      .recipe-grid(style="margin-top: 2rem;")
        - for (let i = 0; i < 3; i++)
          .recipe-card
            .card-img-placeholder.skeleton(style="border-radius: 4px 4px 0 0; border: none; background: transparent; color: transparent;")
            .card-body
              .skeleton.skeleton-text(style="height: 16px; width: 85%; margin-bottom: 1rem;")
              .card-author(style="margin-bottom: 1rem;")
                .avatar-xs.skeleton(style="color:transparent;")
                .skeleton.skeleton-text(style="height: 12px; width: 45%; margin-top: 4px; margin-left: 0.5rem;")
              .card-meta
                .skeleton.skeleton-text(style="height: 12px; width: 35%; margin-top: auto;")
    .sidebar
      .sidebar-card
        h4 Recent Contributors
        .contributor-item
          .avatar-md.skeleton(style="color:transparent;")
          .contributor-info(style="width: 100%;")
            .skeleton.skeleton-text
            .skeleton.skeleton-text.short
        .contributor-item
          .avatar-md.skeleton(style="color:transparent;")
          .contributor-info(style="width: 100%;")
            .skeleton.skeleton-text
            .skeleton.skeleton-text.short
        .contributor-item
          .avatar-md.skeleton(style="color:transparent;")
          .contributor-info(style="width: 100%;")
            .skeleton.skeleton-text
            .skeleton.skeleton-text.short

      .sidebar-card
        h4 Latest Reviews
        .review-item
          .skeleton.skeleton-text(style="height: 14px; width: 40%; margin-bottom: 0.75rem;")
          .skeleton.skeleton-text(style="height: 10px; width: 100%;")
          .skeleton.skeleton-text(style="height: 10px; width: 85%;")
        .review-item
          .skeleton.skeleton-text(style="height: 14px; width: 40%; margin-bottom: 0.75rem;")
          .skeleton.skeleton-text(style="height: 10px; width: 100%;")
          .skeleton.skeleton-text(style="height: 10px; width: 75%;")

      .sidebar-card
        h4 Trending Tags
        .tags-wrap
          span.tag.skeleton(style="width: 50px; color:transparent; border:none;") V
          span.tag.skeleton(style="width: 60px; color:transparent; border:none;") I
          span.tag.skeleton(style="width: 55px; color:transparent; border:none;") B
          span.tag.skeleton(style="width: 40px; color:transparent; border:none;") G
          span.tag.skeleton(style="width: 65px; color:transparent; border:none;") Q
          span.tag.skeleton(style="width: 45px; color:transparent; border:none;") A

block scripts
  script(src="/js/search.js")