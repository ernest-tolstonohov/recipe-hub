extends ../layout.pug

block content
  .container.page-container
    .detail-header.profile-header
      .avatar-md #{profileUser.username.charAt(0).toUpperCase()}
      .recipe-title-section
        h1 @#{profileUser.username}
        .meta-strip.profile-meta-strip
          .meta-item
            span.meta-val #{recipes ? recipes.length : 0}
            span.meta-label Recipes Published
          .meta-item
            span.meta-val #{profileUser.role.toUpperCase()}
            span.meta-label Account Role

    h2.profile-recipes-heading Published Recipes

    if recipes && recipes.length > 0
      .recipe-grid
        each recipe in recipes
          .recipe-card(onclick=`window.location.href='/recipes/${recipe.id}'`)
            .card-img-placeholder
              if recipe.image_url
                img.card-img-fill(src=recipe.image_url, alt=recipe.title)
              else
                span.placeholder-icon 🍽️
            .card-body
              h3 #{recipe.title}
              .card-author
                .avatar-xs #{profileUser.username.charAt(0).toUpperCase()}
                span @#{profileUser.username}
              .card-meta
                span.stars ★★★★★
    else
      .empty-state
        span.empty-icon 👨‍🍳
        h3 No recipes yet
        p @#{profileUser.username} hasn't published any recipes yet.
