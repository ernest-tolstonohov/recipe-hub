extends ../layout

block content
    .container
        .section-header(style="margin-top: 2rem; display: flex; justify-content: space-between; align-items: center;")
            span(style="font-size: 1.5rem; font-weight: bold; color: var(--navy);") My Recipes
            a.btn-green(href="/recipes/new" style="text-decoration:none; padding:0.5rem 1rem;") + Create New
            
        .recipe-grid(style="margin-top: 2rem;")
            each recipe in recipes
                .recipe-card(onclick=`window.location.href='/recipes/${recipe.id}'`, style="cursor: pointer;")
                    .card-img-placeholder
                        if recipe.image_url
                            img(src=recipe.image_url, style="width:100%; height:100%; object-fit:cover;")
                        else
                            span(style="font-size:3rem; color:#d1d5db;") 🍽️
                    .card-body
                        h3 #{recipe.title}
                        .card-meta
                            span.stars(style="color: #fcc419;") ★★★★★
                            span.tag.tag-green Published
            else
                .empty-state(style="grid-column: 1 / -1; text-align: center; padding: 4rem; background: var(--white); border: 1px solid var(--border); border-radius: 8px;")
                    p You haven't created any recipes yet.
                    a.btn-green(href="/recipes/new", style="display:inline-block; margin-top: 1rem; text-decoration:none;") Create Recipe
