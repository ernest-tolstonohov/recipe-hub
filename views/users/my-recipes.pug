extends ../layout

block content
    .container.page-container

        .section-header
            div
                h1 My Recipes
                p Manage your published recipes
            a.btn-green(href="/recipes/new") + Create New

        if recipes && recipes.length > 0
            .recipe-grid
                each recipe in recipes
                    .recipe-card.recipe-card-relative
                        .card-img-placeholder(onclick=`window.location.href='/recipes/${recipe.id}'`)
                            img.card-img-fill(src=recipe.image_url, alt=recipe.title)
                        .card-body
                            h3(onclick=`window.location.href='/recipes/${recipe.id}'`) #{recipe.title}
                            .card-author
                                .avatar-xs #{recipe.author ? recipe.author.charAt(0).toUpperCase() : 'U'}
                                span.text-muted-sm @#{recipe.author}
                            .card-meta
                                span.text-muted-sm
                                    | ★ #{parseFloat(recipe.avg_rating) > 0 ? parseFloat(recipe.avg_rating).toFixed(1) : 'No reviews'}
                                span.difficulty-badge(class=`diff-${recipe.difficulty}`) #{recipe.difficulty}
                            .card-actions
                                a.btn-card-edit(href=`/recipes/${recipe.id}/edit`) ✏️ Edit
                                button.btn-card-delete.btn-delete(data-id=recipe.id) 🗑️ Delete
        else
            .empty-state
                span.empty-icon 👨‍🍳
                h3 No recipes yet
                p Share your first recipe with the community!
                a.btn-green(href="/recipes/new") Create Recipe

block scripts
    script.
        document.querySelectorAll('.btn-delete').forEach(btn => {
            btn.addEventListener('click', async () => {
                if (!confirm('Delete this recipe? This cannot be undone.')) return;
                const id = btn.dataset.id;
                const res = await fetch(`/recipes/${id}`, { method: 'DELETE' });
                if (res.ok) {
                    btn.closest('.recipe-card').remove();
                } else {
                    alert('Failed to delete recipe.');
                }
            });
        });
