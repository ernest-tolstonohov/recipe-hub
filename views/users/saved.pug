extends ../layout

block content
    .container.page-container

        .section-header
            div
                h1 Saved Recipes
                p Your personal collection of favorites

        if saved && saved.length > 0
            .recipe-grid
                each recipe in saved
                    .recipe-card.recipe-card-relative
                        a.card-link(href=`/recipes/${recipe.id}`)
                            .card-img-placeholder
                                if recipe.image_url
                                    img.card-img-fill(src=recipe.image_url, alt=recipe.title)
                                else
                                    span.placeholder-icon 🍽️
                            .card-body
                                h3 #{recipe.title}
                                .card-author
                                    .avatar-xs #{recipe.author ? recipe.author.charAt(0).toUpperCase() : 'U'}
                                    span @#{recipe.author}
                                .card-meta
                                    span.stars ★★★★★
                        if user && user.id === profileUser.id
                            button.btn-unsave.btn.btn-unsave(data-recipe-id=recipe.id, data-user-id=user.id) 🗑️ Remove
        else
            .empty-state
                span.empty-icon 🍽️
                h3 No saved recipes yet
                p Browse recipes and save your favorites!
                a.btn-green(href="/") Explore Recipes

block scripts
    script(src="/js/bookmark.js")
